  padding-top: 8rpx;
  padding-bottom: 8rpx;
  padding-left: 18rpx;
  padding-right: 18rpx;
  border-radius: 999rpx;
  background-color: #eef3f7;
  color: #607386;
  font-size: 22rpx;
}

