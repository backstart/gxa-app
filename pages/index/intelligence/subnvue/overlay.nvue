  background-color: #133452;
  color: #f7fbff;
}

.panel-content {
  min-height: 100vh;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  padding-bottom: 12rpx;
  background-color: rgba(255, 255, 255, 0.97);
}

.search-bar {
  margin-top: 8rpx;
  flex-direction: row;
  align-items: center;
}

.search-shell {
  flex: 1;
  flex-direction: row;
  align-items: center;
  min-width: 0;
