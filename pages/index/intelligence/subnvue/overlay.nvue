}

.quick-actions {
  margin-top: 18rpx;
  flex-direction: row;
  justify-content: space-between;
}

.action-card {
  width: 132rpx;
  border-radius: 22rpx;
  padding-top: 18rpx;
  padding-bottom: 14rpx;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.92);
}

.action-card.active {
  background-color: #17324b;
}

.action-icon {
  width: 72rpx;
